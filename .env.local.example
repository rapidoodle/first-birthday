# Copy to .env.local for local dev. On Vercel, add these under
# Project → Settings → Environment Variables (then redeploy).

# ── Supabase (RSVP, guestbook, photo uploads) ─────────────
# From supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# "service_role" secret key — server-only, used for photo uploads. Keep private!
SUPABASE_SERVICE_ROLE_KEY=

# ── Privacy ───────────────────────────────────────────────
# The "magic word" guests type to enter the site (put it on the invitation).
# Leave empty to keep the site open (e.g. during local dev).
SITE_PASSCODE=

# Password for the hidden /admin photo-upload page (for Mama & Papa).
ADMIN_PASSWORD=
